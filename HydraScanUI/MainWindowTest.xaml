<Window x:Class="HydraScanUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HydraScan Enterprise" Height="850" Width="1300">
    <Grid>
        <Grid x:Name="DashboardView"></Grid>
        <Grid x:Name="ScanView"></Grid>
        <ComboBox x:Name="ScanTypeCombo"></ComboBox>
        <TextBox x:Name="TargetInput"></TextBox>
        <TextBlock x:Name="LblApkPath"></TextBlock>
        <ScrollViewer x:Name="TerminalScroll"></ScrollViewer>
        <TextBlock x:Name="TerminalOutput"></TextBlock>
        <TextBlock x:Name="LblTotal"></TextBlock>
        <TextBlock x:Name="LblActive"></TextBlock>
        <TextBlock x:Name="LblFailed"></TextBlock>
    </Grid>
</Window>
