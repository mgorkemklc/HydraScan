<Window x:Class="HydraScanUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HydraScan Enterprise" Height="850" Width="1300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Colors based on the provided dashboard image -->
        <SolidColorBrush x:Key="AppBgBrush" Color="#FF0F111A"/>
        <SolidColorBrush x:Key="SidebarBgBrush" Color="#FF191C2B"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#FF1F2235"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#FF2A2E45"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#FF8B8F9E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FF2A2F45"/>

        <Style x:Key="SidebarMenuRadio" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="15,0" x:Name="border">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>

        <Style x:Key="UpgradeBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Padding="15,8" x:Name="brd">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#3B82F6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </Window.Resources>

    <Border Background="{StaticResource AppBgBrush}" CornerRadius="15" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}" CornerRadius="15,0,0,15">
                <Grid Margin="0,30,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- LOGO -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="25,0,0,40">
                        <TextBlock Text="❄" Foreground="#6366F1" FontSize="24" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="45"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                        <TextBlock Text="SMARTNET" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- MENU -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <!-- Search -->
                            <Border Background="{StaticResource AppBgBrush}" CornerRadius="8" Margin="20,0,20,20" Height="40" Padding="15,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" Text="Search..." Width="150"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Menu" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="25,0,0,10"/>
                            <RadioButton Content="🏠  Dashboard" Style="{StaticResource SidebarMenuRadio}" IsChecked="True" Checked="NavDashboard_Checked"/>
                            <RadioButton Content="⌖  New Scan" Style="{StaticResource SidebarMenuRadio}" Checked="NavScan_Checked"/>
                            <RadioButton Content="🛡  Data Security      12" Style="{StaticResource SidebarMenuRadio}"/>
                            <RadioButton Content="💻  Shadow IT" Style="{StaticResource SidebarMenuRadio}"/>
                            <RadioButton Content="👥  User Behavior" Style="{StaticResource SidebarMenuRadio}"/>

                            <TextBlock Text="Manage" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="25,25,0,10"/>
                            <RadioButton Content="📁  Destinations" Style="{StaticResource SidebarMenuRadio}"/>
                            <RadioButton Content="🔒  Protection" Style="{StaticResource SidebarMenuRadio}"/>
                            <RadioButton Content="📊  Reports Archive" Style="{StaticResource SidebarMenuRadio}" Checked="NavReports_Checked"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- UPGRADE BOX -->
                    <Border Grid.Row="2" Margin="20,10,20,0" CornerRadius="15" Padding="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4F46E5" Offset="0" />
                                <GradientStop Color="#8B5CF6" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="Go Pro 👑" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="Stay Connected with your team" Foreground="#D8B4FE" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            <Button Content="Upgrade Now" Style="{StaticResource UpgradeBtnStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CONTENT AREA -->
            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOP HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cyber Security Dashboard" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Protecting digital assets is vital. Cybersecurity shields against online threats." Foreground="{StaticResource TextMutedBrush}" FontSize="13" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Tiny Search -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="20" Height="40" Padding="15,0" Margin="0,0,20,0" Width="250">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" Text="Type to search..." Width="180"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Width="36" Height="36" Margin="0,0,10,0">
                            <TextBlock Text="🔔" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Width="36" Height="36" Margin="0,0,10,0">
                            <TextBlock Text="💬" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Width="36" Height="36" Margin="0,0,20,0">
                            <TextBlock Text="⚙" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="20" Height="40" Padding="5,0,15,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="30" Height="30" Fill="#A855F7" Margin="0,0,10,0"/> <!-- Mock Photo -->
                                <TextBlock Text="Robert" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text=" ▼" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- DYNAMIC CONTENT (DASHBOARD OR SCAN) -->
                <Grid Grid.Row="1">
                    
                    <!-- ================= DASHBOARD VIEW ================= -->
                    <Grid x:Name="DashboardView" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Dashboard Title Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="Dashboard" Foreground="White" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15,8" HorizontalAlignment="Right">
                                <TextBlock Text="Add policy  ▼" Foreground="White" FontSize="13"/>
                            </Border>
                        </Grid>

                        <!-- 4 CARDS -->
                        <Grid Grid.Row="1" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card 1 (Total Scans) -->
                            <Border Grid.Column="0" Style="{StaticResource StatCardBorder}" Background="#6D28D9">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="💼  Total Scans" Foreground="#DDD6FE" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="LblTotal" Text="29" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,15,0,0"/>
                                        <TextBlock Text="of 38 total" Foreground="#DDD6FE" FontSize="12"/>
                                    </StackPanel>
                                    <!-- Donut Mock -->
                                    <Ellipse Width="40" Height="40" Stroke="#8B5CF6" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                    <Path Data="M 25,0 A 25,25 0 1 1 5,40" Stroke="White" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5"/>
                                    <TextBlock Text="80%" Foreground="White" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,13"/>
                                </Grid>
                            </Border>

                            <!-- Card 2 (Active Scans) -->
                            <Border Grid.Column="1" Style="{StaticResource StatCardBorder}" Background="#2563EB">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="📄  Active Scans" Foreground="#BFDBFE" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="LblActive" Text="08" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,15,0,0"/>
                                        <TextBlock Text="of 26 total" Foreground="#BFDBFE" FontSize="12"/>
                                    </StackPanel>
                                    <Ellipse Width="40" Height="40" Stroke="#3B82F6" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                    <Path Data="M 25,0 A 25,25 0 0 1 50,20" Stroke="White" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5"/>
                                    <TextBlock Text="32%" Foreground="White" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,13"/>
                                </Grid>
                            </Border>

                            <!-- Card 3 (Failed Scans) -->
                            <Border Grid.Column="2" Style="{StaticResource StatCardBorder}" Background="#A855F7">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="👤  Failed Scans" Foreground="#E9D5FF" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="LblFailed" Text="06" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,15,0,0"/>
                                        <TextBlock Text="of 09 total" Foreground="#E9D5FF" FontSize="12"/>
                                    </StackPanel>
                                    <Ellipse Width="40" Height="40" Stroke="#C084FC" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                    <Path Data="M 25,0 A 25,25 0 1 1 5,40" Stroke="White" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5"/>
                                    <TextBlock Text="60%" Foreground="White" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,13"/>
                                </Grid>
                            </Border>

                            <!-- Card 4 (Devices) -->
                            <Border Grid.Column="3" Style="{StaticResource StatCardBorder}" Background="#EC4899" Margin="0">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="📱  Devices with issues" Foreground="#FBCFE8" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="01" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,15,0,0"/>
                                        <TextBlock Text="of 12 total" Foreground="#FBCFE8" FontSize="12"/>
                                    </StackPanel>
                                    <Ellipse Width="40" Height="40" Stroke="#F472B6" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="10%" Foreground="White" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,13"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- BOTTOM AREA: Split Chart & Settings -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Content: Spline Chart & Terminal -->
                            <Grid Grid.Column="0" Margin="0,0,20,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- BIG SPLINE CHART "Files in time" -->
                                <Border Grid.Row="0" Background="{StaticResource CardBgBrush}" CornerRadius="15" Padding="20" Margin="0,0,0,20">
                                    <Grid>
                                        <TextBlock Text="Files in time" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                        <Border Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,5" HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <TextBlock Text="Investigate  ▼" Foreground="White" FontSize="12"/>
                                        </Border>
                                        
                                        <!-- Fake Spline Geometry via Paths -->
                                        <Grid Margin="0,40,0,20">
                                            <!-- Grid lines -->
                                            <Line X1="0" Y1="0" X2="500" Y2="0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1" VerticalAlignment="Bottom"/>
                                            <Line X1="0" Y1="0" X2="500" Y2="0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1" VerticalAlignment="Center"/>
                                            <Line X1="0" Y1="0" X2="500" Y2="0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1" VerticalAlignment="Top"/>
                                            
                                            <!-- Purple Area -->
                                            <Path Stretch="Fill" Stroke="#A855F7" StrokeThickness="3">
                                                <Path.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#80A855F7" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Path.Fill>
                                                <Path.Data>
                                                    <PathGeometry>
                                                        <PathFigure StartPoint="0,150">
                                                            <BezierSegment Point1="50,150" Point2="100,50" Point3="250,50"/>
                                                            <BezierSegment Point1="350,50" Point2="450,150" Point3="550,130"/>
                                                            <LineSegment Point="550,180"/>
                                                            <LineSegment Point="0,180"/>
                                                        </PathFigure>
                                                    </PathGeometry>
                                                </Path.Data>
                                            </Path>

                                            <!-- Blue Area -->
                                            <Path Stretch="Fill" Stroke="#3B82F6" StrokeThickness="3">
                                                <Path.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#803B82F6" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Path.Fill>
                                                <Path.Data>
                                                    <PathGeometry>
                                                        <PathFigure StartPoint="0,180">
                                                            <BezierSegment Point1="100,100" Point2="150,120" Point3="250,150"/>
                                                            <BezierSegment Point1="350,180" Point2="400,80" Point3="550,60"/>
                                                            <LineSegment Point="550,180"/>
                                                            <LineSegment Point="0,180"/>
                                                        </PathFigure>
                                                    </PathGeometry>
                                                </Path.Data>
                                            </Path>
                                            
                                            <!-- Tooltip Node Mock -->
                                            <Ellipse Width="12" Height="12" Fill="#A855F7" Stroke="White" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,35,0,0"/>
                                            <Border Background="{StaticResource AppBgBrush}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-10,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="$3,900" Foreground="White" FontWeight="Bold"/>
                                                    <TextBlock Text="July" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- TERMINAL AREA (Replacing "Learn safely...") -->
                                <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" CornerRadius="15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,15">
                                            <TextBlock Text=">_ Live System Terminal" Foreground="#34D399" FontWeight="Bold" FontSize="14"/>
                                        </Border>
                                        <Border Grid.Row="1" Background="#0A0D14" CornerRadius="0,0,15,15" Padding="20">
                                            <ScrollViewer x:Name="TerminalScroll">
                                                <TextBlock x:Name="TerminalOutput" Foreground="#22D3EE" FontFamily="Consolas" FontSize="13" LineHeight="20" TextWrapping="Wrap"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Border>

                            </Grid>

                            <!-- Right Content: Environment Settings -->
                            <Border Grid.Column="1" Background="{StaticResource CardBgBrush}" CornerRadius="15" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Environment settings" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                    
                                    <StackPanel Grid.Row="1">
                                        <!-- Item 1 -->
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="✉" Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Email notifications" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Width="220"/>
                                                    <TextBlock Text="›" Foreground="{StaticResource TextMutedBrush}" FontSize="18" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="Activate email notifications for risky events to be informed." Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap"/>
                                                <TextBlock Text="Read more" Foreground="#8B8F9E" TextDecorations="Underline" FontSize="11" Margin="0,5,0,0" Cursor="Hand"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Item 2 -->
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="💻" Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Devices with issues" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Width="220"/>
                                                    <TextBlock Text="›" Foreground="{StaticResource TextMutedBrush}" FontSize="18" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="Fix issues with Safetica on devices to maintain full visibility." Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap"/>
                                                <TextBlock Text="Read more" Foreground="#8B8F9E" TextDecorations="Underline" FontSize="11" Margin="0,5,0,0" Cursor="Hand"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Item 3 -->
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="🔍" Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Investigations" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Width="220"/>
                                                    <TextBlock Text="›" Foreground="{StaticResource TextMutedBrush}" FontSize="18" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="Leverage investigations to faster discover and analyze events." Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap"/>
                                                <TextBlock Text="Read more" Foreground="#8B8F9E" TextDecorations="Underline" FontSize="11" Margin="0,5,0,0" Cursor="Hand"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Item 4 -->
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="📄" Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                <TextBlock Text="Reporting" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Width="220"/>
                                                <TextBlock Text="›" Foreground="{StaticResource TextMutedBrush}" FontSize="18" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Activate the weekly report to receive summary info about environment." Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                    </Grid>

                    <!-- ================= SCAN VIEW ================= -->
                    <Grid x:Name="ScanView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,30">
                            <TextBlock Text="New Target Configuration" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="Define your target and launch penetration testing modules." Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1">
                            <Border Background="{StaticResource CardBgBrush}" CornerRadius="15" Padding="30" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Target Settings" Foreground="#6366F1" FontWeight="Bold" Margin="0,0,0,20"/>
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox x:Name="ScanTypeCombo" Width="200" Height="45" Background="#2A2F45" Foreground="White" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,20,0">
                                            <ComboBoxItem Content="🌐 Web App Scan" IsSelected="True"/>
                                            <ComboBoxItem Content="📱 Mobile API Analysis"/>
                                            <ComboBoxItem Content="🖥️ Internal Network"/>
                                        </ComboBox>
                                        <Border Background="{StaticResource AppBgBrush}" CornerRadius="8" Width="400" Height="45" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <TextBox x:Name="TargetInput" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14" VerticalContentAlignment="Center" Margin="15,0" 
                                                     Text="Enter target URL or IP..." GotFocus="TargetInput_GotFocus" LostFocus="TargetInput_LostFocus"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource CardBgBrush}" CornerRadius="15" Padding="30" Margin="0,0,0,30">
                                <StackPanel>
                                    <TextBlock Text="Mobile Analysis (Optional APK)" Foreground="#6366F1" FontWeight="Bold" Margin="0,0,0,20"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="📁 Select APK" Width="140" Height="45" Background="#2A2F45" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSelectApk_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <TextBlock x:Name="LblApkPath" Text="Selected File: None" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="20,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button Content="🚀 LAUNCH SYSTEM" Style="{StaticResource UpgradeBtnStyle}" Height="60" FontSize="18" Click="StartScan_Click" Width="250" HorizontalAlignment="Left" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <!-- ================= REPORTS VIEW ================= -->
                    <Grid x:Name="ReportsView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="Reports Archive" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="Review past penetration test results and AI reports." Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="350"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Scans List -->
                            <Border Grid.Column="0" Background="{StaticResource CardBgBrush}" CornerRadius="15" Padding="15" Margin="0,0,20,0">
                                <StackPanel>
                                    <TextBlock Text="Past Scans" Foreground="#6366F1" FontWeight="Bold" Margin="0,0,0,15"/>
                                    <Button x:Name="BtnRefreshReports" Content="🔄 Refresh" Foreground="White" Background="{StaticResource HoverBrush}" BorderThickness="0" Padding="5,5" Margin="0,0,0,10" Cursor="Hand" Click="BtnRefreshReports_Click"/>
                                    <ListBox x:Name="ReportsList" Background="Transparent" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="ReportsList_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource AppBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10" Width="290" Cursor="Hand">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding target_full_domain}" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding created_at}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,5,0,0"/>
                                                        <TextBlock Text="{Binding status}" Foreground="#34D399" FontSize="11" FontWeight="Bold" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <!-- Report Details -->
                            <Border Grid.Column="1" Background="{StaticResource CardBgBrush}" CornerRadius="15" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock x:Name="LblReportDetailTitle" Text="Select a report to view details" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                    
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="ReportFindingsList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource AppBgBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding arac_adi}" Foreground="#A855F7" FontWeight="Bold" FontSize="16"/>
                                                                <Border Grid.Column="1" Background="{Binding risk_color}" CornerRadius="5" Padding="8,4">
                                                                    <TextBlock Text="{Binding risk_seviyesi}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                                </Border>
                                                            </Grid>
                                                            <TextBlock Text="SUMMARY:" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,5,0,2"/>
                                                            <TextBlock Text="{Binding ozet}" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                            
                                                            <TextBlock Text="DETAILS:" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,5,0,2"/>
                                                            <ItemsControl ItemsSource="{Binding bulgular}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}" Foreground="#CBD5E1" TextWrapping="Wrap" Margin="10,2,0,2"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            
                                                            <TextBlock Text="RECOMMENDATIONS:" Foreground="#34D399" FontSize="12" FontWeight="Bold" Margin="0,15,0,2"/>
                                                            <ItemsControl ItemsSource="{Binding oneriler}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}" Foreground="#CBD5E1" TextWrapping="Wrap" Margin="10,2,0,2"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
